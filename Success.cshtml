@model ciceksepetim.Models.Order
@{
    ViewData["Title"] = "Teşekkürler!";
}

<div class="container py-5 text-center">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card border-0 shadow-lg rounded-5 overflow-hidden">
                <div class="py-5" style="background: linear-gradient(135deg, #e8f5e9 0%, #f1f8e9 100%);">
                    <div class="display-1 mb-3">🌸</div>
                    <h2 class="fw-bold text-success mb-2">Siparişiniz Alındı!</h2>
                    <p class="lead text-muted">Çiçekleriniz sevgiyle hazırlanmaya başladı.</p>
                </div>

                <div class="card-body p-5">
                    <div class="row g-4 mb-5">
                        <div class="col-6 border-end">
                            <small class="text-uppercase text-muted fw-bold d-block mb-1">Sipariş No</small>
                            <span class="fs-4 fw-bold text-dark">#@Model.Id</span>
                        </div>
                        <div class="col-6">
                            <small class="text-uppercase text-muted fw-bold d-block mb-1">Toplam Tutar</small>
                            <span class="fs-4 fw-bold text-success">@Model.Total?.ToString("C2")</span>
                        </div>
                    </div>

                    <div class="alert border-0 rounded-4 p-4 mb-5" style="background-color: #fce4ec; color: #c2185b;">
                        <i class="fas fa-info-circle me-2"></i>
                        Sipariş detayları <strong>@User.Identity?.Name</strong> adresine e-posta olarak gönderilmiştir.
                    </div>

                    <div class="d-flex flex-column flex-md-row gap-3 justify-content-center">
                        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-success btn-lg rounded-pill px-5 fw-bold">
                            <i class="fas fa-home me-2"></i> Anasayfaya Dön
                        </a>
                        <a asp-controller="Orders" asp-action="Index" class="btn btn-success btn-lg rounded-pill px-5 fw-bold shadow">
                            Siparişimi Takip Et <i class="fas fa-truck ms-2"></i>
                        </a>
                    </div>
                </div>

                <div class="card-footer bg-white border-0 pb-4 opacity-50">
                    <div class="d-flex justify-content-center gap-4">
                        <i class="fab fa-cc-visa fa-2x"></i>
                        <i class="fab fa-cc-mastercard fa-2x"></i>
                        <i class="fas fa-shield-check fa-2x"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>