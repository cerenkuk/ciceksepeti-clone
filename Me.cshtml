@{
    ViewData["Title"] = "Hesabım";
    var name = User.Identity?.Name ?? "Kullanıcı";
    var email = User.FindFirst("email")?.Value ?? "";
}

<style>
    .profile-header {
        background: linear-gradient(135deg, var(--soft-green) 0%, #ffffff 100%);
        border-radius: 40px;
        border: 2px solid var(--soft-green);
        position: relative;
        overflow: hidden;
    }

        .profile-header::after {
            content: '🌸';
            position: absolute;
            right: 20px;
            bottom: -10px;
            font-size: 5rem;
            opacity: 0.2;
        }

    .account-card {
        border-radius: 25px;
        border: 2px solid transparent;
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        background: white;
    }

        .account-card:hover {
            transform: translateY(-12px);
            border-color: var(--soft-pink);
            box-shadow: 0 15px 30px rgba(255, 209, 220, 0.3) !important;
        }

    .icon-box {
        width: 70px;
        height: 70px;
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        margin: 0 auto 1.5rem;
    }

    .btn-view {
        border-radius: 50px;
        font-weight: 700;
        transition: 0.3s;
    }
</style>

<div class="container mt-4">
    @* Profil Başlık Kartı *@
    <div class="profile-header p-5 mb-5 shadow-sm">
        <div class="row align-items-center">
            <div class="col-auto">
                <div class="bg-white shadow-sm rounded-circle d-flex align-items-center justify-content-center border border-2 border-success"
                     style="width: 100px; height: 100px; font-size: 3rem;">
                    👤
                </div>
            </div>
            <div class="col">
                <h1 class="fw-bold mb-1" style="color: #2E7D32;">Hoş Geldin, @name!</h1>
                <p class="text-muted mb-0"><i class="far fa-envelope me-2"></i>@email</p>
                <span class="badge bg-success-subtle text-success rounded-pill px-3 mt-2">Aktif Üye 🌸</span>
            </div>
        </div>
    </div>

    @* Aksiyon Kartları *@
    <div class="row g-4">
        @{
            var cards = new[] {
                new { Title = "Siparişlerim", Text = "Siparişlerini takip et", Icon = "📦", Bg = "#E8F5E9", TextColor = "#2E7D32", Action = "Index", Controller = "Orders" },
                new { Title = "Yorumlarım", Text = "Deneyimlerini paylaş", Icon = "⭐", Bg = "#FFF9C4", TextColor = "#F57F17", Action = "Reviews", Controller = "Account" },
                new { Title = "Mesajlarım", Text = "Bize soru sor", Icon = "💬", Bg = "#E3F2FD", TextColor = "#1565C0", Action = "Messages", Controller = "Account" },
                new { Title = "Profilim", Text = "Bilgilerini düzenle", Icon = "⚙️", Bg = "#FCE4EC", TextColor = "#C2185B", Action = "Profile", Controller = "Account" }
                };
        }

        @foreach (var item in cards)
        {
            <div class="col-md-6 col-lg-3">
                <div class="card h-100 border-0 shadow-sm text-center p-4 account-card">
                    <div class="card-body">
                        <div class="icon-box" style="background-color: @item.Bg;">
                            @item.Icon
                        </div>
                        <h5 class="fw-bold mb-2">@item.Title</h5>
                        <p class="text-muted small mb-4">@item.Text</p>
                        <a asp-controller="@item.Controller" asp-action="@item.Action"
                           class="btn btn-view w-100"
                           style="background-color: @item.Bg; color: @item.TextColor;">
                            Yönet →
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>