@model List<ciceksepetim.Models.AppUser>
@{
    ViewData["Title"] = "Satıcı İşlemleri";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold"><i class="fas fa-store text-info me-2"></i> Satıcı Yönetimi</h2>
        <a asp-action="CreateSeller" class="btn btn-success rounded-pill px-4 shadow-sm">
            <i class="fas fa-plus me-2"></i> Yeni Satıcı Ekle
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 py-3">Satıcı Bilgileri</th>
                        <th>Durum</th>
                        <th class="text-end pe-4">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var seller in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="fw-bold text-dark">@seller.FullName</div>
                                <div class="text-muted small">@seller.Email</div>
                            </td>
                            <td>
                                @if (seller.IsApproved)
                                {
                                    <span class="badge bg-success-subtle text-success border border-success-subtle rounded-pill px-3">Aktif Satıcı</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning-subtle text-warning border border-warning-subtle rounded-pill px-3">Onay Bekliyor</span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <div class="btn-group shadow-sm rounded-3 overflow-hidden">
                                    @if (!seller.IsApproved)
                                    {
                                        <form asp-action="ApproveSeller" method="post" style="display:inline;">
                                            <input type="hidden" name="id" value="@seller.Id" />
                                            <button type="submit" class="btn btn-white btn-sm text-success px-3 border-end">Onayla</button>
                                        </form>
                                    }
                                    <form asp-action="RejectSeller" method="post" style="display:inline;">
                                        <input type="hidden" name="id" value="@seller.Id" />
                                        <button type="submit" class="btn btn-white btn-sm text-danger px-3">Reddet / Sil</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>