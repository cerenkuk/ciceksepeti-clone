@model ciceksepetim.Models.Product

@{
    ViewData["Title"] = "Yeni Ürün Ekle";
    var categories = ViewBag.Categories as List<ciceksepetim.Models.Category> ?? new List<ciceksepetim.Models.Category>();
}

<style>
    :root {
        --soft-pink: #FFD1DC;
        --deep-pink: #FF85A1;
        --soft-green: #E8F5E9;
        --mint-green: #66BB6A;
        --text-dark: #4A4A4A;
    }

    body {
        background-color: #FAFAFA;
        color: var(--text-dark);
    }

    .form-header {
        background: white;
        border-radius: 25px;
        border-left: 8px solid var(--mint-green);
        box-shadow: 0 10px 30px rgba(0,0,0,0.03);
    }

    .form-card {
        border: none;
        border-radius: 25px;
        background: white;
        box-shadow: 0 15px 35px rgba(0,0,0,0.05);
    }

    .section-divider {
        color: var(--mint-green);
        border-bottom: 2px solid var(--soft-green);
        padding-bottom: 8px;
        margin-bottom: 25px;
        font-weight: 800;
        text-transform: uppercase;
        font-size: 0.85rem;
        letter-spacing: 1px;
    }

    .form-control, .form-select {
        border: 1px solid var(--soft-green);
        border-radius: 15px;
        padding: 12px 15px;
    }

        .form-control:focus, .form-select:focus {
            border-color: var(--deep-pink);
            box-shadow: 0 0 0 0.25rem rgba(255, 133, 161, 0.1);
        }

    .input-group-text {
        background-color: var(--soft-green);
        border-color: var(--soft-green);
        color: var(--mint-green);
        border-radius: 15px 0 0 15px;
    }

    .btn-save {
        background: var(--mint-green);
        border: none;
        color: white;
        border-radius: 50px;
        padding: 12px 35px;
        font-weight: 700;
        transition: all 0.3s ease;
    }

        .btn-save:hover {
            background: #57a95b;
            transform: translateY(-2px);
        }
</style>

<div class="container py-5">
    <div class="form-header p-4 mb-4 d-flex justify-content-between align-items-center">
        <div class="d-flex align-items-center gap-3">
            <div class="bg-light rounded-circle p-3 d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                <span class="fs-2">➕</span>
            </div>
            <div>
                <h1 class="h3 fw-bold mb-0">Yeni Ürün Ekle</h1>
                <p class="mb-0 text-muted small">Kataloğunuzu zenginleştirin</p>
            </div>
        </div>
        <a asp-action="Products" class="btn btn-outline-secondary rounded-pill px-4 fw-bold shadow-sm border-0 bg-light">
            <i class="fas fa-arrow-left me-1"></i> Ürünlere Dön
        </a>
    </div>

    <div class="card form-card">
        <div class="card-body p-4 p-md-5">
            <form asp-action="CreateProduct" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 rounded-4 small mb-4"></div>

                <h5 class="section-divider"><i class="fas fa-info-circle me-2"></i>Genel Bilgiler</h5>
                <div class="row g-4 mb-5">
                    <div class="col-md-6">
                        <label asp-for="Name" class="form-label fw-bold">Ürün Adı</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="fas fa-tag"></i></span>
                            <input asp-for="Name" class="form-control" placeholder="Örn: Beyaz Papatya Buketi" required />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Slug" class="form-label fw-bold">URL Slug</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="fas fa-link"></i></span>
                            <input asp-for="Slug" class="form-control" placeholder="beyaz-papatya-buketi" />
                        </div>
                    </div>
                </div>

                <h5 class="section-divider"><i class="fas fa-camera me-2"></i>Görünüm & Maliyet</h5>
                <div class="row g-4 mb-5">
                    <div class="col-md-6">
                        <label asp-for="ImageUrl" class="form-label fw-bold">Görsel URL</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="fas fa-image"></i></span>
                            <input asp-for="ImageUrl" class="form-control" placeholder="https://..." />
                        </div>
                    </div>
                    <div class="col-md-3">
                        <label asp-for="Price" class="form-label fw-bold">Fiyat (₺)</label>
                        <div class="input-group">
                            <span class="input-group-text fw-bold">₺</span>
                            <input asp-for="Price" type="number" step="0.01" class="form-control" required />
                        </div>
                    </div>
                    <div class="col-md-3">
                        <label asp-for="Stock" class="form-label fw-bold">Stok</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="fas fa-cubes"></i></span>
                            <input asp-for="Stock" type="number" class="form-control" required />
                        </div>
                    </div>
                </div>

                <h5 class="section-divider"><i class="fas fa-list me-2"></i>Kategori Yönetimi</h5>
                <div class="mb-5">
                    <label asp-for="CategorySlug" class="form-label fw-bold">Kategori Seçimi</label>
                    <select asp-for="CategorySlug" class="form-select">
                        <option value="">-- Kategori Seçin --</option>
                        @foreach (var c in categories)
                        {
                            <option value="@c.Slug">@c.Name</option>
                        }
                    </select>
                </div>

                <div class="d-flex justify-content-end gap-3 pt-4 border-top">
                    <a asp-action="Products" class="btn btn-light rounded-pill px-4 fw-bold">İptal</a>
                    <button type="submit" class="btn btn-save shadow-sm">
                        <i class="fas fa-heart me-2"></i>Ürünü Kaydet
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>