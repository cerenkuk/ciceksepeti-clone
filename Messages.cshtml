@model List<ciceksepetim.Models.Message>
@{
    ViewData["Title"] = "Mesaj Kutusu";
}

<style>
    :root {
        --soft-pink: #FFD1DC;
        --deep-pink: #FF85A1;
        --soft-green: #E8F5E9;
        --mint-green: #66BB6A;
        --text-dark: #4A4A4A;
    }

    body {
        background-color: #FAFAFA;
    }

    .msg-header {
        background: white;
        border-radius: 25px;
        border-left: 8px solid var(--soft-pink);
        box-shadow: 0 10px 30px rgba(0,0,0,0.03);
    }

    .message-card {
        border: none;
        border-radius: 20px;
        background: white;
        transition: all 0.3s ease;
        cursor: pointer;
    }

        .message-card:hover {
            transform: translateX(10px);
            box-shadow: 0 10px 20px rgba(102, 187, 106, 0.1) !important;
        }

    .unread-border {
        border-left: 5px solid var(--deep-pink) !important;
    }

    .avatar-circle {
        width: 55px;
        height: 55px;
        background-color: var(--soft-green);
        color: var(--mint-green);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 800;
        font-size: 1.3rem;
        border: 2px solid white;
        box-shadow: 0 4px 10px rgba(0,0,0,0.05);
    }

    .badge-new {
        background-color: var(--deep-pink);
        color: white;
        font-weight: 700;
        border-radius: 50px;
        padding: 5px 12px;
    }

    .btn-view {
        background-color: var(--soft-pink);
        color: var(--deep-pink);
        border: none;
        font-weight: 700;
        border-radius: 50px;
        transition: all 0.3s;
    }

        .btn-view:hover {
            background-color: var(--deep-pink);
            color: white;
        }
</style>

<div class="container py-5">
    <div class="msg-header p-4 mb-4 d-flex align-items-center justify-content-between flex-wrap gap-3">
        <div class="d-flex align-items-center gap-3">
            <div class="bg-light rounded-circle p-3 d-flex align-items-center justify-content-center" style="width:60px; height:60px;">
                <span class="fs-2">✉️</span>
            </div>
            <div>
                <h1 class="h3 fw-bold mb-0">Mesajlarım</h1>
                <p class="mb-0 text-muted small">Müşterilerinizden gelen çiçekli notlar.</p>
            </div>
        </div>
        <div class="badge bg-white text-success border border-success rounded-pill px-3 py-2 fw-bold">
            @Model.Count(m => !m.IsReadByRecipient && m.RecipientEmail == User.Identity.Name) Yeni Mesaj
        </div>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="text-center py-5 bg-white rounded-4 shadow-sm">
            <div class="display-1 mb-3">🕊️</div>
            <h3 class="fw-bold">Henüz mesaj yok</h3>
            <p class="text-muted">Gelen kutunuz şu an çok sakin...</p>
        </div>
    }
    else
    {
        <div class="d-flex flex-column gap-3 mt-4">
            @foreach (var message in Model)
            {
                string sellerEmail = User.Identity.Name;
                bool isUnread = message.RecipientEmail == sellerEmail && !message.IsReadByRecipient;
                var displaySender = message.SenderEmail == sellerEmail ? "Siz" : message.SenderEmail;

                <div class="card message-card shadow-sm @(isUnread ? "unread-border" : "")">
                    <div class="card-body p-4">
                        <div class="row align-items-center">
                            <div class="col-auto">
                                <div class="avatar-circle">
                                    @(displaySender[0].ToString().ToUpper())
                                </div>
                            </div>
                            <div class="col">
                                <div class="d-flex justify-content-between">
                                    <h5 class="fw-bold mb-1">@message.Subject</h5>
                                    <small class="text-muted">@message.SentDate.ToString("dd MMM HH:mm")</small>
                                </div>
                                <div class="d-flex align-items-center gap-2 mt-1">
                                    <span class="small text-secondary">Kimden: <strong>@displaySender</strong></span>
                                    @if (isUnread)
                                    {
                                        <span class="badge badge-new small">YENİ</span>
                                    }
                                </div>
                            </div>
                            <div class="col-auto">
                                <a asp-action="MessageDetail" asp-route-id="@message.Id" class="btn btn-view btn-sm px-4">
                                    Oku <i class="fas fa-arrow-right ms-1"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>