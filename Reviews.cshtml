@model List<ciceksepetim.Models.Review>
@{
    ViewData["Title"] = "Değerlendirmeler";
}

<style>
    :root {
        --soft-pink: #FFD1DC;
        --deep-pink: #FF85A1;
        --soft-green: #E8F5E9;
        --mint-green: #66BB6A;
    }

    body {
        background-color: #FAFAFA;
    }

    .review-card {
        border: none;
        border-radius: 25px;
        background: white;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    }

    .table thead th {
        background-color: var(--soft-green);
        color: var(--mint-green);
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 1px;
        padding: 15px;
        border: none;
    }

    .rating-badge {
        background: var(--soft-pink);
        color: var(--deep-pink);
        font-weight: 800;
        border-radius: 12px;
        padding: 8px 12px;
    }

    .comment-box {
        background: #fdfdfd;
        border-left: 4px solid var(--soft-pink);
        padding: 10px 15px;
        border-radius: 10px;
        font-style: italic;
        color: #666;
    }

    .btn-delete {
        width: 38px;
        height: 38px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--deep-pink);
        background: var(--chat-pink);
        transition: all 0.3s;
        border: none;
    }

        .btn-delete:hover {
            background: var(--deep-pink);
            color: white;
        }
</style>

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-end mb-4">
        <div>
            <h2 class="fw-bold d-flex align-items-center gap-2">
                <span style="color: var(--deep-pink)">🌸</span> Mağaza Yorumları
            </h2>
            <p class="text-muted mb-0">Toplam @Model.Count müşteriniz geri bildirimde bulundu.</p>
        </div>
        <a asp-action="Dashboard" class="btn btn-light rounded-pill px-4 fw-bold shadow-sm">
            <i class="fas fa-chevron-left me-2"></i>Panele Dön
        </a>
    </div>

    @if (TempData["ok"] != null)
    {
        <div class="alert alert-success border-0 shadow-sm rounded-4 mb-4" role="alert">
            <i class="fas fa-check-circle me-2"></i> @TempData["ok"]
        </div>
    }

    <div class="card review-card overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th class="ps-4">Ürün</th>
                        <th>Müşteri</th>
                        <th class="text-center">Değerlendirme</th>
                        <th style="width: 40%;">Yorum</th>
                        <th>Tarih</th>
                        <th class="pe-4 text-end">İşlem</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var review in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <span class="fw-bold text-dark">@review.Product?.Name</span>
                            </td>
                            <td>
                                <div class="small fw-bold text-muted">@review.UserEmail.Split('@')[0]***</div>
                            </td>
                            <td class="text-center">
                                <span class="rating-badge">
                                    @review.Rating.ToString("N1") <i class="fas fa-star ms-1"></i>
                                </span>
                            </td>
                            <td>
                                <div class="comment-box small">"@review.Comment"</div>
                            </td>
                            <td class="small text-muted">@review.ReviewDate.ToString("dd/MM/yyyy")</td>
                            <td class="pe-4 text-end">
                                <form asp-action="DeleteReview" asp-route-id="@review.Id" method="post" onsubmit="return confirm('Silinsin mi?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn-delete ms-auto">
                                        <i class="fas fa-trash-alt"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>