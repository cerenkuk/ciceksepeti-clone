@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Yeni Satıcı Kaydı | Admin</title>
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <style>
        :root {
            --soft-pink: #FFD1DC;
            --mint-green: #66BB6A;
            --soft-green: #E8F5E9;
        }

        body, html {
            height: 100%;
            margin: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: radial-gradient(circle, #ffffff 0%, #f4fff4 100%);
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .seller-card {
            background: white;
            width: 100%;
            max-width: 480px;
            border-radius: 35px;
            overflow: hidden;
            box-shadow: 0 25px 50px rgba(0,0,0,0.08);
            border: 2px solid var(--soft-pink);
        }

        .card-header-gradient {
            background: linear-gradient(135deg, #7e57c2 0%, #26c6da 100%);
            padding: 50px 30px;
            text-align: center;
            color: white;
            position: relative;
        }

            .card-header-gradient h2 {
                font-weight: 800;
                letter-spacing: -1px;
            }

        .card-body-form {
            padding: 40px;
        }

        .input-soft {
            border-radius: 15px;
            border: 2px solid #f5f5f5;
            padding: 15px;
            background: #fdfdfd;
            transition: 0.3s;
        }

            .input-soft:focus {
                border-color: var(--mint-green);
                background: #fff;
                box-shadow: none;
            }

        /* İstediğin Soft Pembe-Yeşil Geçişli Buton */
        .btn-gradient-custom {
            background: linear-gradient(135deg, var(--mint-green) 0%, #a8e6cf 50%, var(--soft-pink) 100%);
            background-size: 200% auto;
            border: none;
            border-radius: 50px;
            padding: 14px 30px;
            font-weight: 700;
            color: #444;
            transition: 0.5s;
            box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        }

            .btn-gradient-custom:hover {
                background-position: right center;
                transform: translateY(-2px);
                color: #222;
            }

        .btn-cancel {
            background: #f5f5f5;
            color: #888;
            border-radius: 50px;
            padding: 14px 25px;
            border: none;
            font-weight: 600;
            transition: 0.3s;
        }

            .btn-cancel:hover {
                background: #eee;
                color: #444;
            }
    </style>
</head>
<body>

    <div class="seller-card">
        <div class="card-header-gradient">
            <div class="mb-3"><i class="fas fa-store-alt fa-3x"></i></div>
            <h2>Yeni Mağaza Ekle</h2>
            <p class="mb-0 opacity-75">Bahçemize yeni bir satıcı davet edin.</p>
        </div>

        <div class="card-body-form">
            <form asp-action="CreateSeller" asp-controller="Admin" method="post">
                <div class="form-group mb-4">
                    <label class="small fw-bold text-muted ml-2">Mağaza Adı</label>
                    <input type="text" name="fullName" class="form-control input-soft" placeholder="Örn: Papatya Bahçesi" required />
                </div>

                <div class="form-group mb-4">
                    <label class="small fw-bold text-muted ml-2">E-posta Adresi</label>
                    <input type="email" name="email" class="form-control input-soft" placeholder="magaza@email.com" required />
                </div>

                <div class="form-group mb-4">
                    <label class="small fw-bold text-muted ml-2">Başlangıç Şifresi</label>
                    <input type="password" name="password" class="form-control input-soft" placeholder="••••••••" required />
                </div>

                <div class="d-flex align-items-center justify-content-between mt-5">
                    <a asp-action="Sellers" asp-controller="Admin" class="btn btn-cancel">İptal</a>
                    <button type="submit" class="btn btn-gradient-custom shadow-sm">
                        Kaydı Tamamla <i class="fas fa-check-circle ml-1"></i>
                    </button>
                </div>
            </form>
        </div>
    </div>

</body>
</html>