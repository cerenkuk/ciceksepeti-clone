@model List<ciceksepetim.Models.Product>
@{
    ViewData["Title"] = "Ürünlerim";
}

<style>
    :root {
        --soft-pink: #FFD1DC;
        --deep-pink: #FF85A1;
        --soft-green: #E8F5E9;
        --mint-green: #66BB6A;
        --text-dark: #4A4A4A;
    }

    body {
        background-color: #FAFAFA;
        color: var(--text-dark);
    }

    /* Üst Banner */
    .inventory-header {
        background: white;
        border-radius: 25px;
        border-left: 8px solid var(--soft-pink);
        box-shadow: 0 10px 30px rgba(0,0,0,0.03);
    }

    .btn-add-product {
        background-color: var(--deep-pink);
        color: white;
        border: none;
        padding: 12px 30px;
        border-radius: 50px;
        font-weight: 700;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(255, 133, 161, 0.3);
    }

        .btn-add-product:hover {
            background-color: #ff6b8d;
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(255, 133, 161, 0.4);
        }

    /* Ürün Kartları */
    .product-card {
        border: none;
        border-radius: 20px;
        background: white;
        transition: all 0.3s ease;
        overflow: hidden;
        box-shadow: 0 5px 15px rgba(0,0,0,0.04);
    }

        .product-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 15px 30px rgba(255, 133, 161, 0.1) !important;
        }

    .image-container {
        height: 200px;
        overflow: hidden;
        background-color: var(--soft-green);
        position: relative;
    }

    .product-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s ease;
    }

    .product-card:hover .product-img {
        transform: scale(1.1);
    }

    .category-badge {
        background-color: var(--soft-green);
        color: var(--mint-green);
        font-size: 0.75rem;
        font-weight: 700;
        padding: 5px 12px;
        border-radius: 50px;
    }

    .price-box {
        background-color: #FFF9FA;
        border: 1px dashed var(--soft-pink);
        border-radius: 15px;
        padding: 10px;
    }

    .price-text {
        color: var(--deep-pink);
        font-weight: 800;
        font-size: 1.2rem;
    }

    /* Butonlar */
    .btn-edit {
        background-color: var(--soft-green);
        color: var(--mint-green);
        border: none;
        border-radius: 12px;
        font-weight: 600;
        transition: all 0.2s;
    }

        .btn-edit:hover {
            background-color: var(--mint-green);
            color: white;
        }

    .btn-delete {
        background-color: #FFF0F3;
        color: #FF4D6D;
        border: none;
        border-radius: 12px;
        transition: all 0.2s;
    }

        .btn-delete:hover {
            background-color: #FF4D6D;
            color: white;
        }
</style>

<div class="container py-5">
    <div class="inventory-header p-4 mb-5 d-flex align-items-center justify-content-between flex-wrap gap-3">
        <div class="d-flex align-items-center gap-3">
            <div class="bg-light rounded-circle p-3 d-flex align-items-center justify-content-center" style="width:60px; height:60px;">
                <span class="fs-2">🌸</span>
            </div>
            <div>
                <h1 class="h3 fw-bold mb-0" style="color: var(--text-dark)">Ürünlerim</h1>
                <p class="mb-0 text-muted small">Mağazanızdaki çiçekleri ve hediyeleri yönetin.</p>
            </div>
        </div>
        <a asp-controller="Seller" asp-action="CreateProduct" class="btn btn-add-product">
            <i class="fas fa-plus-circle me-2"></i>Yeni Ürün Ekle
        </a>
    </div>

    @if (Model == null || Model.Count == 0)
    {
        <div class="text-center py-5 bg-white rounded-4 shadow-sm border-0">
            <div class="display-1 mb-3">🪴</div>
            <h3 class="fw-bold text-dark">Henüz ürününüz yok</h3>
            <p class="text-muted mb-4 px-3">Mağazanız henüz boş görünüyor. İlk ürününüzü ekleyerek satışa hemen başlayabilirsiniz!</p>
            <a asp-action="CreateProduct" class="btn btn-add-product px-5 shadow">Ürününü Oluştur</a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var p in Model)
            {
                <div class="col-md-6 col-lg-4 col-xl-3">
                    <div class="card h-100 product-card">
                        <div class="image-container">
                            @if (!string.IsNullOrEmpty(p.ImageUrl))
                            {
                                <img src="@p.ImageUrl" alt="@p.Name" class="product-img" />
                            }
                            else
                            {
                                <div class="w-100 h-100 d-flex flex-column align-items-center justify-content-center text-muted">
                                    <i class="fas fa-image fa-3x mb-2 opacity-25"></i>
                                    <span class="small fw-bold opacity-50">Görsel Yok</span>
                                </div>
                            }
                            <div class="position-absolute top-0 start-0 m-2">
                                <span class="badge bg-white bg-opacity-75 text-dark rounded-pill px-2 py-1 small">#@p.Id</span>
                            </div>
                        </div>

                        <div class="card-body p-4 d-flex flex-column">
                            <div class="mb-2">
                                <span class="category-badge">@p.CategorySlug</span>
                            </div>
                            <h5 class="card-title fw-bold text-dark mb-3 text-truncate" title="@p.Name">@p.Name</h5>

                            <div class="mt-auto price-box d-flex align-items-center justify-content-between">
                                <span class="small fw-bold text-muted">FİYAT</span>
                                <span class="price-text">@p.Price.ToString("C2")</span>
                            </div>
                        </div>

                        <div class="card-footer bg-white border-0 p-3 pt-0">
                            <div class="row g-2">
                                <div class="col-8">
                                    <a asp-action="EditProduct" asp-route-id="@p.Id" class="btn btn-edit w-100 py-2">
                                        <i class="fas fa-magic me-1"></i> Düzenle
                                    </a>
                                </div>
                                <div class="col-4">
                                    <form asp-action="DeleteProduct" asp-route-id="@p.Id" method="post" class="h-100">
                                        <button type="submit" class="btn btn-delete w-100 h-100 py-2" onclick="return confirm('Bu güzel ürünü silmek istediğinize emin misiniz?');">
                                            <i class="fas fa-trash-alt"></i>
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>