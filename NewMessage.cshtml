@model ciceksepetim.Models.Message
@{
    ViewData["Title"] = "Yeni Mesaj";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-0 shadow-lg rounded-4 p-4" style="border-top: 5px solid var(--soft-pink) !important;">
                <div class="text-center mb-4">
                    <div class="display-4 mb-2">🌿</div>
                    <h2 class="fw-bold text-dark">Destek Talebi</h2>
                    <p class="text-muted small">Size nasıl yardımcı olabiliriz?</p>
                </div>

                <form asp-controller="Account" asp-action="NewMessage" method="post">
                    <form asp-controller="Account" asp-action="NewMessage" method="post">
                        <input type="hidden" asp-for="RelatedOrderId" />

                        <div class="mb-3">
                            <label asp-for="Subject" class="form-label small fw-bold text-muted ms-1">Konu Başlığı</label>
                            <input asp-for="Subject" class="form-control form-control-custom" placeholder="Örn: Sipariş Durumu" required />
                        </div>
                    </form>
                    <div class="mb-3">
                        <label asp-for="Subject" class="form-label small fw-bold text-muted ms-1">Konu Başlığı</label>
                        <input asp-for="Subject" class="form-control form-control-custom" placeholder="Örn: Sipariş Durumu" required />
                    </div>

                    <div class="mb-3">
                        <label asp-for="MessageType" class="form-label small fw-bold text-muted ms-1">Mesaj Türü</label>
                        <select asp-for="MessageType" class="form-select form-control-custom" required>
                            <option value="">Seçiniz...</option>
                            <option value="Product">🌸 Ürünle İlgili</option>
                            <option value="Order">📦 Siparişle İlgili</option>
                            <option value="Billing">💳 Fatura/Ödeme</option>
                            <option value="General">💬 Genel Destek</option>
                        </select>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Content" class="form-label small fw-bold text-muted ms-1">Mesajınız</label>
                        <textarea asp-for="Content" class="form-control form-control-custom" rows="5" placeholder="Süreci hızlandırmak için detayları buraya yazabilirsiniz..." required style="resize: none;"></textarea>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-login shadow-sm">Mesajı Gönder ✨</button>
                        <a asp-action="Messages" class="btn btn-link text-muted text-decoration-none small mt-1">Vazgeç ve Dön</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>