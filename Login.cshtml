@model ciceksepetim.Models.LoginViewModel
@{
    ViewData["Title"] = "Giriş Yap";
}

<style>
    .auth-wrap {
        min-height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: radial-gradient(circle, #ffffff 0%, #f4fff4 100%);
    }

    .auth-card {
        background: white;
        padding: 3rem;
        border-radius: 35px;
        box-shadow: 0 20px 50px rgba(0,0,0,0.03);
        width: 100%;
        max-width: 420px;
        border: 2px solid var(--soft-pink);
    }

    .btn-auth-gradient {
        background: linear-gradient(135deg, var(--soft-pink) 0%, #fce4ec 50%, var(--mint-green) 100%);
        background-size: 200% auto;
        color: #5d4037;
        border: none;
        border-radius: 50px;
        padding: 12px;
        font-weight: 700;
        width: 100%;
        transition: 0.5s;
    }

        .btn-auth-gradient:hover {
            background-position: right center;
            transform: translateY(-2px);
            color: #2e7d32;
        }

    .form-input-soft {
        border-radius: 15px;
        border: 2px solid #f5f5f5;
        padding: 12px;
        background: #fdfdfd;
    }

        .form-input-soft:focus {
            border-color: var(--soft-pink);
            background: #fffafa;
            box-shadow: none;
        }
</style>

<section class="auth-wrap">
    <div class="auth-card">
        <div class="text-center mb-4">
            <span style="font-size: 3rem;">🌸</span>
            <h2 class="fw-bold mt-2" style="color: #5d4037;">Tekrar Merhaba</h2>
            <p class="text-muted small">Çiçekli dünyamıza giriş yapın</p>
        </div>

        <form asp-action="Login" method="post">
            <div class="mb-3">
                <label class="small fw-bold text-muted ms-2">E-posta</label>
                <input asp-for="Email" class="form-control form-input-soft" placeholder="ornek@email.com" />
            </div>

            <div class="mb-3">
                <label class="small fw-bold text-muted ms-2">Şifre</label>
                <div class="input-group">
                    <input asp-for="Password" type="password" class="form-control form-input-soft border-end-0" id="pwdInput" placeholder="••••••" style="border-radius: 15px 0 0 15px;" />
                    <button class="btn border-2 border-start-0 bg-light" type="button" onclick="toggleLoginPwd()" style="border-color:#f5f5f5; border-radius: 0 15px 15px 0;">👁️</button>
                </div>
            </div>

            <div class="mb-4 d-flex align-items-center gap-2 ms-2">
                <input asp-for="RememberMe" class="form-check-input" style="cursor: pointer;" />
                <label class="small text-muted mb-0">Beni Hatırla</label>
            </div>

            <button type="submit" class="btn btn-auth-gradient shadow-sm mb-4">Bahçeye Gir 🚀</button>

            <p class="text-center small text-muted">
                Henüz üye değil misin? <a asp-action="Register" class="fw-bold text-decoration-none" style="color: var(--mint-green);">Hesap Oluştur</a>
            </p>
        </form>
    </div>
</section>

<script>
    function toggleLoginPwd() {
        var x = document.getElementById("pwdInput");
        x.type = x.type === "password" ? "text" : "password";
    }
</script>