@model ciceksepetim.Models.ProfileViewModel
@{
    ViewData["Title"] = "Üyelik Bilgilerim";
}

<style>
    .profile-card {
        border-radius: 30px;
        border: 2px solid var(--soft-pink) !important;
        background: white;
    }

    .info-box {
        background: var(--soft-green);
        border: 1px solid #e0ede0;
        border-radius: 20px;
        padding: 20px;
        transition: 0.3s;
    }

        .info-box:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.03);
        }

    .status-alert {
        background-color: #fff9f9;
        border-radius: 20px;
        border: 2px dashed var(--soft-pink);
    }
</style>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card profile-card shadow-sm overflow-hidden">
                <div class="card-header bg-white border-0 py-4 px-4 text-center">
                    <div class="display-6 mb-2">🌸</div>
                    <h2 class="fw-bold mb-0 text-dark">Üyelik Bilgilerim</h2>
                    <p class="text-muted small">Profil ayarlarınızı buradan yönetebilirsiniz</p>
                </div>
                <div class="card-body p-4">
                    <div class="row g-4">
                        <div class="col-md-6">
                            <div class="info-box">
                                <label class="text-success small fw-bold text-uppercase mb-1 d-block">Ad Soyad</label>
                                <div class="fs-5 fw-semibold text-dark">@Model.FullName</div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="info-box">
                                <label class="text-success small fw-bold text-uppercase mb-1 d-block">E-posta Adresi</label>
                                <div class="fs-5 fw-semibold text-dark">@Model.Email</div>
                            </div>
                        </div>
                    </div>

                    <div class="mt-5 p-4 status-alert">
                        <div class="d-flex align-items-center">
                            <div class="me-3 fs-3">⏳</div>
                            <div>
                                <h6 class="fw-bold text-dark mb-1">Geliştirme Aşamasında</h6>
                                <p class="mb-0 text-muted small">
                                    Bilgileriniz şu an sadece görüntülenebilir. Düzenleme ve şifre değiştirme özellikleri çok yakında bahçemize eklenecek!
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>