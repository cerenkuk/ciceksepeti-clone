@model ciceksepetim.Models.SearchVM
@{
    ViewData["Title"] = "Ürün Ara";
    string Mark(string text, string q)
    {
        if (string.IsNullOrWhiteSpace(q)) return text;
        var idx = text?.IndexOf(q, StringComparison.OrdinalIgnoreCase) ?? -1;
        if (idx < 0) return text;
        var hit = text.Substring(idx, q.Length);
        return text.Replace(hit, $"<mark class='bg-warning-subtle p-0'>{hit}</mark>", StringComparison.OrdinalIgnoreCase);
    }
}

<div class="container py-5">
    <div class="card border-0 shadow-sm rounded-5 p-4 mb-5" style="background-color: #f1f8e9;">
        <form method="get" asp-action="Index">
            <div class="row g-3 align-items-end">
                <div class="col-md-5">
                    <label class="small fw-bold text-success mb-2 ms-2 text-uppercase">Ne Aramıştınız?</label>
                    <input name="q" value="@Model.Q" class="form-control rounded-pill border-0 py-3 px-4 shadow-sm" placeholder="Gül, orkide, sukulent...">
                </div>
                <div class="col-md-4">
                    <label class="small fw-bold text-success mb-2 ms-2 text-uppercase">Kategori</label>
                    <select name="cat" class="form-select rounded-pill border-0 py-3 px-4 shadow-sm">
                        <option value="">Tüm Kategoriler</option>
                        @foreach (var c in Model.Categories)
                        {
                            <option value="@c.Slug" selected="@(Model.Cat == c.Slug)">@c.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <button class="btn btn-success btn-lg w-100 rounded-pill py-3 fw-bold shadow-sm">
                        🔍 Ürünleri Bul
                    </button>
                </div>
            </div>
        </form>
    </div>

    @if (string.IsNullOrWhiteSpace(Model.Q))
    {
        <div class="text-center py-5">
            <span class="display-1">🔎</span>
            <h4 class="text-muted mt-3">Hadi, bir şeyler arayalım!</h4>
        </div>
    }
    else if (!Model.Results.Any())
    {
        <div class="text-center py-5">
            <span class="display-1">😔</span>
            <h4 class="fw-bold mt-3">Sonuç Bulunamadı</h4>
            <p class="text-muted">"@Model.Q" araması için uygun bir çiçek bulamadık.</p>
        </div>
    }
    else
    {
        <div class="d-flex justify-content-between align-items-center mb-4 px-2">
            <h4 class="fw-bold mb-0">"<u>@Model.Q</u>" için Sonuçlar</h4>
            <span class="badge bg-light text-dark rounded-pill px-3 border">@Model.Total ürün bulundu</span>
        </div>

        <div class="row g-4">
            @foreach (var p in Model.Results)
            {
                <div class="col-6 col-md-4 col-lg-3">
                    <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden product-card-hover">
                        <a asp-controller="Catalog" asp-action="Detail" asp-route-id="@p.Id">
                            <img src="@p.ImageUrl" class="card-img-top" style="height: 220px; object-fit: cover;">
                        </a>
                        <div class="card-body p-3">
                            <h6 class="fw-bold mb-2">@Html.Raw(Mark(p.Name, Model.Q))</h6>
                            <div class="d-flex justify-content-between align-items-center mt-3">
                                <span class="fs-5 fw-bolder text-success">@p.Price.ToString("C0")</span>
                                <form asp-controller="Cart" asp-action="Add" method="post">
                                    <input type="hidden" name="id" value="@p.Id" />
                                    <button class="btn btn-sm btn-success rounded-circle shadow-sm">
                                        <i class="fas fa-plus p-1"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (Model.Pages > 1)
        {
            <nav class="mt-5 d-flex justify-content-center">
                <ul class="pagination gap-2">
                    @for (var i = 1; i <= Model.Pages; i++)
                    {
                        <li class="page-item">
                            <a class="page-link rounded-circle border-0 fw-bold @(i==Model.Page?"bg-success text-white shadow":"text-success")"
                               asp-action="Index" asp-route-q="@Model.Q" asp-route-cat="@Model.Cat" asp-route-page="@i">@i</a>
                        </li>
                    }
                </ul>
            </nav>
        }
    }
</div>

<style>
    .product-card-hover {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .product-card-hover:hover {
            transform: translateY(-8px);
            box-shadow: 0 15px 35px rgba(0,0,0,0.1) !important;
        }

    .page-link {
        width: 45px;
        height: 45px;
        display: flex;
        align-items: center;
        justify-content: center;
    }
</style>